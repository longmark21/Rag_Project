# 数据库配置
# MySQL数据库连接信息
SPRING_DATASOURCE_PRIMARY_JDBC_URL=jdbc:mysql://localhost:3306/rag_knowledge?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_PRIMARY_USERNAME=root
SPRING_DATASOURCE_PRIMARY_PASSWORD=password

# PostgreSQL向量数据库连接信息
SPRING_DATASOURCE_VECTOR_JDBC_URL=jdbc:postgresql://localhost:5432/rag_vector?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_VECTOR_USERNAME=postgres
SPRING_DATASOURCE_VECTOR_PASSWORD=password

# Redis配置
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0

# 阿里云通义千问API配置
SPRING_AI_DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 应用配置
# 文件上传配置
FILE_UPLOAD_PATH=./uploads
FILE_UPLOAD_MAX_SIZE=500MB
FILE_UPLOAD_ALLOWED_TYPES=pdf,doc,docx,txt

# RAG配置
RAG_RETRIEVAL_TOP_K=3
RAG_RETRIEVAL_SCORE_THRESHOLD=0.7
RAG_CONVERSATION_MAX_HISTORY=10
RAG_CONVERSATION_TTL=3600

# 文本分块配置
TEXT_CHUNK_SIZE=500
TEXT_CHUNK_OVERLAP=50
TEXT_CHUNK_MAX_CHUNK_SIZE=1000
